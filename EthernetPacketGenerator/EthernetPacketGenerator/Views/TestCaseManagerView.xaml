<UserControl x:Class="EthernetPacketGenerator.Views.TestCaseManagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <DockPanel Background="#0B1220">
        <TextBlock DockPanel.Dock="Bottom"
                   Text="{Binding Status}"
                   Foreground="#9FB2CC"
                   FontSize="10"
                   Margin="8,3"
                   TextTrimming="CharacterEllipsis"/>

        <TabControl Background="#0B1220" BorderThickness="0" SelectedIndex="1">
            <TabItem Header="Scenario Sheet">
                <Grid Background="#0B1220">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#101A2B" BorderBrush="#1F2A44" BorderThickness="0,0,0,1" Padding="10,8">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                <Button Content="Open CSV" Command="{Binding LoadScenarioSheetCommand}" Height="26" Padding="10,0" Margin="0,0,6,0"/>
                                <Button Content="Save CSV" Command="{Binding SaveScenarioSheetCommand}" Height="26" Padding="10,0" Margin="0,0,6,0"/>
                                <Button Content="Load FDB Sheet" Command="{Binding LoadFdbScenarioSheetCommand}" Height="26" Padding="10,0" Margin="0,0,6,0"/>
                                <Button Content="+ Row" Command="{Binding AddScenarioRowCommand}" Height="26" Padding="10,0" Margin="0,0,6,0"/>
                                <Button Content="- Row" Command="{Binding DeleteScenarioRowCommand}" Height="26" Padding="10,0" Margin="0,0,6,0"/>
                                <Button Content="Apply to Sequence" Command="{Binding ApplyScenarioSheetCommand}" Height="26" Padding="12,0"/>
                                <Button Content="Validate Capture" Command="{Binding ValidateCaptureCommand}" Height="26" Padding="12,0" Margin="6,0,0,0"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="EXCEL-STYLE TEST SCENARIO" Foreground="#E5EEF8" FontWeight="SemiBold" FontSize="12"/>
                                <TextBlock Text="Human-editable source table. Apply converts rows into the executable sequence on the right."
                                           Foreground="#8AA0BA" FontSize="10" Margin="0,2,0,0"/>
                                <TextBlock Text="{Binding RxPortMappingText}"
                                           Foreground="#7DD3FC"
                                           FontSize="10"
                                           Margin="0,2,0,0"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <Border Grid.Row="1"
                            Background="#07111F"
                            BorderBrush="#1F2A44"
                            BorderThickness="0"
                            ClipToBounds="True">
                    <DataGrid
                              ItemsSource="{Binding ScenarioRows}"
                              SelectedItem="{Binding SelectedScenarioRow, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="True"
                              CanUserDeleteRows="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="All"
                              RowHeaderWidth="0"
                              Background="#07111F"
                              Foreground="#E5EEF8"
                              BorderThickness="0"
                              AlternatingRowBackground="#0B1728"
                              RowBackground="#091322"
                              HorizontalGridLinesBrush="#1F2A44"
                              VerticalGridLinesBrush="#1F2A44"
                              FontFamily="Consolas"
                              FontSize="11"
                              EnableRowVirtualization="True"
                              EnableColumnVirtualization="True"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling"
                              ScrollViewer.CanContentScroll="True"
                              ScrollViewer.HorizontalScrollBarVisibility="Visible"
                              ScrollViewer.VerticalScrollBarVisibility="Visible">
                        <DataGrid.Resources>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#111827"/>
                                <Setter Property="Foreground" Value="#A7B0C4"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Padding" Value="6,4"/>
                            </Style>
                            <Style TargetType="TextBox">
                                <Setter Property="Background" Value="#0B1728"/>
                                <Setter Property="Foreground" Value="#F8FAFC"/>
                                <Setter Property="BorderBrush" Value="#355070"/>
                            </Style>
                        </DataGrid.Resources>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="TC_ID" Binding="{Binding TC_ID, UpdateSourceTrigger=PropertyChanged}" Width="64" MinWidth="54"/>
                            <DataGridTextColumn Header="Scenario_ID" Binding="{Binding Test_Scenario_ID, UpdateSourceTrigger=PropertyChanged}" Width="96" MinWidth="82"/>
                            <DataGridTextColumn Header="Index" Binding="{Binding Index, UpdateSourceTrigger=PropertyChanged}" Width="64" MinWidth="54"/>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Width="200" MinWidth="140"/>
                            <DataGridTextColumn Header="Action" Binding="{Binding Action, UpdateSourceTrigger=PropertyChanged}" Width="100" MinWidth="90"/>
                            <DataGridTextColumn Header="Address" Binding="{Binding Address, UpdateSourceTrigger=PropertyChanged}" Width="112" MinWidth="100"/>
                            <DataGridTextColumn Header="Value / MAC" Binding="{Binding Value, UpdateSourceTrigger=PropertyChanged}" Width="140" MinWidth="120"/>
                            <DataGridTextColumn Header="Mask" Binding="{Binding Mask, UpdateSourceTrigger=PropertyChanged}" Width="110" MinWidth="100"/>
                            <DataGridTextColumn Header="Expected / Port" Binding="{Binding Expected, UpdateSourceTrigger=PropertyChanged}" Width="130" MinWidth="115"/>
                            <DataGridTextColumn Header="Timeout" Binding="{Binding Timeout, UpdateSourceTrigger=PropertyChanged}" Width="90" MinWidth="80"/>
                            <DataGridTextColumn Header="Observed RX" Binding="{Binding Observed, UpdateSourceTrigger=PropertyChanged}" Width="220" MinWidth="160"/>
                            <DataGridTextColumn Header="Result" Binding="{Binding Result, UpdateSourceTrigger=PropertyChanged}" Width="80" MinWidth="70"/>
                            <DataGridTextColumn Header="Note" Binding="{Binding Note, UpdateSourceTrigger=PropertyChanged}" Width="320" MinWidth="180"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Saved Test Cases">
                <DockPanel Background="#0F172A">
                    <Border DockPanel.Dock="Top" Background="#101A2B" BorderBrush="#1F2A44" BorderThickness="0,0,0,1" Padding="10,8">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                <Button Content="+ Group" Command="{Binding AddGroupCommand}" Height="26" Padding="10,0" Margin="0,0,6,0"/>
                                <Button Content="Delete" Command="{Binding DeleteCommand}" Height="26" Padding="10,0" Margin="0,0,6,0"/>
                                <Button Content="Open .tcs" Command="{Binding LoadFileCommand}" Height="26" Padding="10,0" Margin="0,0,6,0"/>
                                <Button Content="Save .tcs" Command="{Binding SaveFileCommand}" Height="26" Padding="10,0" Margin="0,0,6,0"/>
                                <Button Content="Save Current Sequence" Command="{Binding SaveTcCommand}" Height="26" Padding="12,0"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="SAVED TEST CASES" Foreground="#E5EEF8" FontWeight="SemiBold" FontSize="12"/>
                                <TextBlock Text="Original TCS tree. Selecting a TC loads its saved sequence."
                                           Foreground="#8AA0BA" FontSize="10" Margin="0,2,0,0"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Groups}" Tag="{Binding DataContext, ElementName=Root}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <DockPanel Background="#1C2B38" Margin="4,3,4,0" Height="26">
                                            <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                                     Background="Transparent"
                                                     BorderThickness="0"
                                                     Foreground="#E5EEF8"
                                                     FontWeight="SemiBold"
                                                     FontSize="11"
                                                     VerticalContentAlignment="Center"
                                                     Padding="8,0"/>
                                            <Button DockPanel.Dock="Right"
                                                    Content="+ TC"
                                                    Height="22"
                                                    Margin="0,2,4,2"
                                                    Padding="8,0"
                                                    Command="{Binding DataContext.AddTcToGroupCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"/>
                                        </DockPanel>

                                        <ItemsControl ItemsSource="{Binding TestCases}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Button Padding="18,3,6,3"
                                                            HorizontalAlignment="Stretch"
                                                            HorizontalContentAlignment="Stretch"
                                                            Command="{Binding DataContext.SelectTcCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}">
                                                        <Button.Style>
                                                            <Style TargetType="Button">
                                                                <Setter Property="Background" Value="Transparent"/>
                                                                <Setter Property="BorderThickness" Value="0"/>
                                                                <Setter Property="Foreground" Value="#CAD7EA"/>
                                                                <Style.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="Background" Value="#22304A"/>
                                                                    </Trigger>
                                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                        <Setter Property="Background" Value="#1D4ED8"/>
                                                                        <Setter Property="Foreground" Value="White"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                        <DockPanel>
                                                            <TextBlock DockPanel.Dock="Right"
                                                                       Text="{Binding Items.Count, StringFormat={}{0} rows}"
                                                                       Foreground="#8AA0BA"
                                                                       FontSize="10"
                                                                       Margin="8,0,0,0"/>
                                                            <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                                                     Background="Transparent"
                                                                     BorderThickness="0"
                                                                     Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                                     FontSize="11"
                                                                     Padding="0"/>
                                                        </DockPanel>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </TabItem>
        </TabControl>
    </DockPanel>
</UserControl>
