<UserControl x:Class="EthernetPacketGenerator.Views.PacketListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:EthernetPacketGenerator.Models">
    <DockPanel Background="{StaticResource SurfaceBrush}">

        <!-- Header -->
        <TextBlock DockPanel.Dock="Top" Text="TEST SEQUENCE" Style="{StaticResource PanelHeader}"/>

        <!-- Toolbar -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="4,4,4,2">
            <Button Content="+" ToolTip="Add Packet" Width="28" Command="{Binding AddPacketCommand}"/>
            <Button Content="-" ToolTip="Delete"     Width="28" Margin="3,0,0,0" Command="{Binding DeleteItemCommand}"/>
            <Button Content="⧉" ToolTip="Duplicate" Width="28" Margin="3,0,0,0" Command="{Binding DuplicatePacketCommand}"/>
            <Button Content="↑" ToolTip="Move Up"    Width="28" Margin="3,0,0,0" Command="{Binding MoveUpCommand}"/>
            <Button Content="↓" ToolTip="Move Down"  Width="28" Margin="3,0,0,0" Command="{Binding MoveDownCommand}"/>
        </StackPanel>

        <!-- Sequence ListView -->
        <ListView x:Name="SequenceList"
                  ItemsSource="{Binding Sequence}"
                  SelectedItem="{Binding SelectedSequenceItem, Mode=TwoWay}"
                  SelectionMode="Single"
                  BorderThickness="0"
                  FontFamily="Consolas" FontSize="11"
                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                  VirtualizingStackPanel.IsVirtualizing="True"
                  VirtualizingStackPanel.VirtualizationMode="Recycling"
                  UseLayoutRounding="True">
            <ListView.View>
                <GridView>
                    <!-- Checkbox (all rows — checked items are included in Send Selected) -->
                    <GridViewColumn Header="" Width="28">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <!-- Index (0-based) -->
                    <GridViewColumn Header="Index" Width="46">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Index}"
                                           Foreground="{StaticResource ForegroundBrush}"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <!-- Name (inline editable for packets, delay label for events) -->
                    <GridViewColumn Header="Name" Width="120">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Grid>
                                    <StackPanel x:Name="PacketPanel" Orientation="Horizontal"
                                                MouseLeftButtonDown="PacketName_MouseLeftButtonDown">
                                        <TextBlock Text="{Binding DisplayName}"
                                                   Foreground="{StaticResource ForegroundBrush}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBox x:Name="EditBox" Visibility="Collapsed"
                                             Text="{Binding Packet.Name, UpdateSourceTrigger=Explicit}"
                                             MinWidth="90"
                                             KeyDown="EditBox_KeyDown"
                                             LostFocus="EditBox_LostFocus"/>
                                    <TextBlock x:Name="EventLabel"
                                               Text="{Binding DisplayName}"
                                               Foreground="#FFAA44" FontStyle="Italic"
                                               VerticalAlignment="Center" Visibility="Collapsed"/>
                                </Grid>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding Kind}" Value="Event">
                                        <Setter TargetName="PacketPanel" Property="Visibility" Value="Collapsed"/>
                                        <Setter TargetName="EventLabel"  Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <!-- Src MAC -->
                    <GridViewColumn Header="Src / Target" Width="150">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplaySrcMac}"
                                           Foreground="{StaticResource ForegroundBrush}"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <!-- Dst MAC -->
                    <GridViewColumn Header="Dst / Value" Width="150">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplayDstMac}"
                                           Foreground="{StaticResource ForegroundBrush}"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <!-- Protocol / Length -->
                    <GridViewColumn Header="Protocol / Params" Width="190">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplayProtocol}"
                                           Foreground="{StaticResource ForegroundBrush}"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <!-- Interface (패킷별 전송 인터페이스 다중 선택) -->
                    <GridViewColumn Header="Interface" Width="180">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Grid>
                                    <!-- Packet row: 드롭다운 버튼 -->
                                    <Grid x:Name="IfaceGrid">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="18"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- 선택된 인터페이스 표시 텍스트 -->
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Packet.OutgoingInterfaceDisplay}"
                                                   FontSize="11" VerticalAlignment="Center"
                                                   Padding="3,0" TextTrimming="CharacterEllipsis"
                                                   Foreground="{StaticResource ForegroundBrush}"/>

                                        <!-- 드롭다운 토글 버튼 -->
                                        <ToggleButton Grid.Column="1"
                                                      x:Name="IfaceToggle"
                                                      Content="▾"
                                                      FontSize="9"
                                                      Padding="0"
                                                      Height="18"
                                                      Background="#2A2A40"
                                                      BorderBrush="#3A3A5A"
                                                      Foreground="#88CCFF"
                                                      Click="InterfaceToggle_Click"/>

                                        <!-- 팝업 체크박스 목록 -->
                                        <Popup x:Name="IfacePopup"
                                               PlacementTarget="{Binding ElementName=IfaceToggle}"
                                               Placement="Bottom"
                                               StaysOpen="False"
                                               IsOpen="{Binding IsChecked, ElementName=IfaceToggle, Mode=TwoWay}"
                                               AllowsTransparency="True"
                                               PopupAnimation="Slide">
                                            <Border Background="#1E1E2E"
                                                    BorderBrush="#3A3A5A"
                                                    BorderThickness="1"
                                                    CornerRadius="3"
                                                    Padding="4,4,4,4"
                                                    MinWidth="160">
                                                <StackPanel x:Name="IfaceCheckList"
                                                            Tag="{Binding}"
                                                            Loaded="IfaceCheckList_Loaded"/>
                                            </Border>
                                        </Popup>
                                    </Grid>
                                    <!-- Event row: 빈 칸 -->
                                    <TextBlock x:Name="IfaceEventLabel" Text="" Visibility="Collapsed"/>
                                </Grid>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding Kind}" Value="Event">
                                        <Setter TargetName="IfaceGrid"       Property="Visibility" Value="Collapsed"/>
                                        <Setter TargetName="IfaceEventLabel" Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <!-- Description -->
                    <GridViewColumn Header="Description" Width="280">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplayDescription}"
                                           Foreground="{StaticResource ForegroundBrush}"
                                           TextTrimming="CharacterEllipsis"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
                    <Setter Property="Padding"    Value="0"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Kind}" Value="Event">
                            <Setter Property="Background" Value="#2A2010"/>
                            <Setter Property="Foreground" Value="#FFAA44"/>
                        </DataTrigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="{StaticResource SelectionBrush}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#2A2A50"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListView.ItemContainerStyle>
        </ListView>
    </DockPanel>
</UserControl>
